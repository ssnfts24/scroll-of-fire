@charset "utf-8";

:root { --bg: #0d0d0d; --parchment: #e8ddc4; --gold: #d4af37; --gold-dim: #9c7c2e; --ink: #1a1208; }

html { scroll-behavior: smooth; }

body { background-color: var(--bg); color: var(--parchment); font-family: "EB Garamond", Georgia, serif; background-image: radial-gradient(at center top, rgba(212, 175, 55, 0.09) 0%, transparent 60%), radial-gradient(at center bottom, rgba(212, 175, 55, 0.06) 0%, transparent 70%), url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E"); }

h1, h2, h3 { font-family: Cinzel, serif; letter-spacing: 0.02em; text-wrap: balance; }

.serif-display { font-family: "Cormorant Garamond", serif; }

.gold { color: var(--gold); }

.parchment-box { background: linear-gradient(rgba(20, 15, 8, 0.85) 0%, rgba(10, 8, 5, 0.92) 100%); border: 1px solid rgba(212, 175, 55, 0.22); box-shadow: rgba(0, 0, 0, 0.6) 0px 0px 40px, rgba(212, 175, 55, 0.03) 0px 0px 40px inset; backdrop-filter: blur(3px); position: relative; }

.parchment-box::before { content: ""; position: absolute; inset: 0px; pointer-events: none; background: radial-gradient(circle at 20% 10%, rgba(212, 175, 55, 0.07), transparent 40%); opacity: 0.5; }

.divider { height: 1px; background: linear-gradient(90deg, transparent, var(--gold-dim), transparent); position: relative; margin: 2.5rem auto; }

.divider::after { content: "✦"; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); background: var(--bg); color: var(--gold-dim); padding: 0px 1.2rem; font-size: 0.75rem; }

.seal { width: 70px; height: 70px; border-radius: 50%; background: radial-gradient(circle at 30% 25%, rgb(122, 28, 28), rgb(58, 10, 10) 55%, rgb(26, 0, 0) 90%); border: 2px solid var(--gold-dim); box-shadow: rgba(0, 0, 0, 0.9) 0px 0px 18px inset, rgba(212, 175, 55, 0.18) 0px 0px 14px, rgba(212, 175, 55, 0.3) 0px 0px 6px inset; display: grid; place-items: center; font-family: Cinzel, serif; color: var(--gold); font-weight: 700; font-size: 1.1rem; }

.timeline-row { transition: 0.25s; cursor: pointer; }

.timeline-row:hover { background: rgba(212, 175, 55, 0.06); }

.timeline-row.cluster { box-shadow: inset 4px 0 0 var(--gold); background: rgba(212, 175, 55, 0.035); }

.timeline-row.active { background: rgba(212, 175, 55, 0.11); }

.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.9s, transform 0.9s; }

.fade-in.visible { opacity: 1; transform: translateY(0px); }

.map-bg { position: fixed; inset: 0px; z-index: -2; opacity: 0.045; background-image: url("https://upload.wikimedia.org/wikipedia/commons/8/8c/1889_birdseye_Seattle_Washington.jpg"); background-size: cover; background-position: center center; mix-blend-mode: luminosity; filter: sepia(1) contrast(1.2) hue-rotate(15deg) brightness(0.4); }

.corner { position: absolute; width: 24px; height: 24px; border-color: rgba(212, 175, 55, 0.35); }

.corner-tl { top: -1px; left: -1px; border-left: 2px solid; border-top: 2px solid; }

.corner-tr { top: -1px; right: -1px; border-right: 2px solid; border-top: 2px solid; }

.corner-bl { bottom: -1px; left: -1px; border-left: 2px solid; border-bottom: 2px solid; }

.corner-br { bottom: -1px; right: -1px; border-right: 2px solid; border-bottom: 2px solid; }

@media (max-width: 768px) {
  .seal { width: 52px; height: 52px; font-size: 0.9rem; }
}
